<!DOCTYPE html>
<html>
  <head>
    <title>Sample App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <div class="container" style="margin-top: 50px;">
      
      <!-- --- НАЧАЛО НОВОГО БЛОКА --- -->
      <nav class="d-flex justify-content-end mb-4">
        <% if logged_in? %>
          <span class="me-3 mt-2 text-muted">Вы вошли как <strong><%= current_user.name %></strong></span>
        <%# Используем button_to вместо link_to — это создаст мини-форму, которая отправит DELETE запрос без помощи JS %>
        <%= button_to "Выйти", logout_path, method: :delete, class: "btn btn-outline-danger btn-sm" %>
        <% else %>
          <%= link_to "Войти", login_path, class: "btn btn-primary btn-sm" %>
        <% end %>
      </nav>
      <!-- --- КОНЕЦ НОВОГО БЛОКА --- -->

      <% flash.each do |message_type, message| %>
        <div class="alert alert-success">
          <%= message %>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>