{
  "name": "app",
  "private": true,
  "dependencies": {
    "@esbuild/linux-x64": "^0.28.0",
    "@hotwired/turbo-rails": "^8.0.23",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.10.0",
    "sass": "^1.99.0"
  },
  "scripts": {
    "build": "npx esbuild app/javascript/*.* --bundle --outdir=app/assets/builds",
    "build:css": "npx sass app/assets/stylesheets/:app/assets/builds/ --no-source-map --load-path=node_modules"
  }
